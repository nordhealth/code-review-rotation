# Required: encrypts session cookies (generate with: openssl rand -hex 32)
NUXT_SESSION_PASSWORD=your-32-char-secret-here

# Required: shared secret for POST /api/rotate endpoint (generate with: openssl rand -hex 32)
NUXT_API_KEY=your-cron-api-key

# Optional: Resend API key for sending emails (confirmation, password reset, invites)
# Without this, email links are logged to console instead of sent
NUXT_RESEND_API_KEY=

# Optional: sender address for outgoing emails (defaults to "Nord Review <onboarding@resend.dev>")
NUXT_EMAIL_FROM=Nord Review <onboarding@resend.dev>
