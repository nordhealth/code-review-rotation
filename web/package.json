{
  "name": "nord-review",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "dev:fresh": "rm -rf .data && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest",
    "test:e2e": "TEST_E2E=true vitest run tests/e2e/",
    "test:playwright": "playwright test"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@nuxthub/core": "^0.10.7",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mdc": "^0.20.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-vue-next": "^0.577.0",
    "nanoid": "^5.1.7",
    "nuxt": "^4.4.2",
    "nuxt-auth-utils": "^0.5.29",
    "nuxt-llms": "^0.2.0",
    "reka-ui": "^2.9.2",
    "resend": "^6.9.4",
    "shadcn-nuxt": "^2.4.3",
    "slugify": "^1.6.8",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.30",
    "vue-sonner": "^2.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@nuxtjs/mcp-toolkit": "^0.12.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "overrides": {
      "h3": "^1.15.6"
    }
  },
  "lint-staged": {
    "*.{js,ts,vue,json,md,yml,yaml}": [
      "eslint --fix"
    ]
  }
}
